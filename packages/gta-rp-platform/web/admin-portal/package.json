{
  "name": "GTA-RP-Admin-Portal",
  "version": "1.0.0",
  "description": "Admin Portal for GTA RP Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd src/frontend && npm run build",
    "build:backend": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.{js,ts}",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-cors": "^0.0.2",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.10.0",
    "redis": "^4.6.5",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.3",
    "socket.io": "^4.5.4",
    "axios": "^1.3.5",
    "joi": "^17.9.1"
  },
  "devDependencies": {
    "@types/node": "^18.15.10",
    "@types/express": "^4.17.17",
    "typescript": "^5.0.2",
    "nodemon": "^2.0.20",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.0",
    "eslint": "^8.37.0"
  }
}
