# Environment Configuration Template
# Copy to .env and fill in your values

# ============== SERVER ==============
PORT=3000
FIVEM_PORT=30120
NODE_ENV=development
LOG_LEVEL=debug

# ============== DATABASE ==============
DB_HOST=postgres
DB_PORT=5432
DB_USER=fivem
DB_PASSWORD=changeme
DB_NAME=fivem_db
DB_SSL=false

# ============== ADMIN PORTAL ==============
ADMIN_SECRET=your-super-secret-key-change-this
ADMIN_PORT=3000
ADMIN_JWT_SECRET=your-jwt-secret-key
ADMIN_SESSION_SECRET=your-session-secret

# ============== SUPPORT DASHBOARD ==============
SUPPORT_PORT=3001
SUPPORT_API_URL=http://localhost:3000

# ============== FIVEM SERVER ==============
SERVER_NAME="GTA RP Platform"
SERVER_DESCRIPTION="Production Roleplay Server"
SERVER_LANGUAGE=english
SERVER_LOCALE=en_US
MAX_CLIENTS=64

# ============== DISCORD (Optional) ==============
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_SERVER_ID=your-discord-server-id
DISCORD_LOG_CHANNEL=your-channel-id

# ============== EMAIL (Optional) ==============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@example.com

# ============== MONITORING ==============
SENTRY_DSN=
REDIS_URL=redis://redis:6379
DATADOG_API_KEY=

# ============== API KEYS ==============
API_KEY_SECRET=your-api-secret
JWT_EXPIRY=24h

# ============== BACKUP ==============
BACKUP_ENABLED=true
BACKUP_INTERVAL=900000
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# ============== SECURITY ==============
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
LOG_PLAYER_IPS=true
BAN_SYSTEM_ENABLED=true
