# GTA RP Enterprise - Environment Configuration

# ========================================
# FIVEM SERVER CONFIGURATION
# ========================================
FIVEM_LICENSE_KEY=your_key_here
FIVEM_SERVER_PORT=30120
FIVEM_HTTP_PORT=3000
FIVEM_MAX_PLAYERS=128
FIVEM_SERVER_NAME=GTA RP Enterprise
FIVEM_SERVER_DESCRIPTION=A production-grade GTA RP server
FIVEM_LANGUAGE=en

# ========================================
# DATABASE CONFIGURATION (MySQL)
# ========================================
FIVEM_DB_HOST=localhost
FIVEM_DB_PORT=3306
FIVEM_DB_USER=fivem_user
FIVEM_DB_PASS=changeme_secure_password
FIVEM_DB_NAME=gta_rp
FIVEM_DB_SSL=false

# ========================================
# TXADMIN CONFIGURATION
# ========================================
TXADMIN_ENABLED=true
TXADMIN_PIN=0000
TXADMIN_PORT=40120
TXADMIN_USERNAME=admin
TXADMIN_PASSWORD=changeme_secure_password

# ========================================
# ADMIN PANEL CONFIGURATION
# ========================================
ADMIN_PANEL_URL=http://localhost:3000
ADMIN_PANEL_PORT=3000
ADMIN_PANEL_SECRET=changeme_random_secret_key_32_chars

# ========================================
# PLAYER PORTAL CONFIGURATION
# ========================================
PLAYER_PORTAL_URL=http://localhost:3001
PLAYER_PORTAL_PORT=3001
PLAYER_PORTAL_SECRET=changeme_random_secret_key_32_chars

# ========================================
# DISCORD CONFIGURATION
# ========================================
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_ADMIN_WEBHOOK=https://discordapp.com/api/webhooks/...
DISCORD_AUDIT_WEBHOOK=https://discordapp.com/api/webhooks/...
DISCORD_WHITELIST_CHANNEL_ID=123456789
DISCORD_APPEAL_CHANNEL_ID=123456789

# ========================================
# AUTHENTICATION & SECURITY
# ========================================
JWT_SECRET=changeme_random_jwt_secret_key_min_32_chars
JWT_EXPIRY=24h
SESSION_SECRET=changeme_random_session_secret
SESSION_TIMEOUT=3600
ENCRYPTION_KEY=changeme_random_encryption_key_32_chars

# ========================================
# EMAIL CONFIGURATION
# ========================================
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com

# ========================================
# LOGGING CONFIGURATION
# ========================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/server.log
LOG_MAX_SIZE=10m

# ========================================
# STORAGE CONFIGURATION
# ========================================
STORAGE_TYPE=s3
AWS_S3_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# ========================================
# REDIS CONFIGURATION
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# CACHE CONFIGURATION
# ========================================
CACHE_TTL=3600
CACHE_TYPE=redis

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# MONITORING & METRICS
# ========================================
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ========================================
# CLOUD PROVIDER (AWS/GCP/Azure)
# ========================================
CLOUD_PROVIDER=aws
CLOUD_REGION=us-east-1
CLOUD_PROJECT_ID=your-project-id

# ========================================
# BACKUP CONFIGURATION
# ========================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=s3://your-backup-bucket

# ========================================
# ANTI-CHEAT CONFIGURATION
# ========================================
ANTICHEAT_ENABLED=true
ANTICHEAT_LEVEL=high
ANTICHEAT_WEBHOOK=https://discordapp.com/api/webhooks/...

# ========================================
# FEATURE FLAGS
# ========================================
FEATURE_WHITELIST_REQUIRED=true
FEATURE_CHARACTER_CREATION=true
FEATURE_PROPERTY_SYSTEM=true
FEATURE_BUSINESS_SYSTEM=true
FEATURE_JOB_SYSTEM=true
FEATURE_VEHICLE_DEALERSHIP=true
FEATURE_ADVANCED_JOBS=true

# ========================================
# PERFORMANCE TUNING
# ========================================
WORKER_THREADS=4
DB_CONNECTION_POOL_SIZE=20
DB_QUERY_TIMEOUT=5000

# ========================================
# DEBUG MODE
# ========================================
DEBUG=false
DEBUG_VERBOSE=false
DEBUG_SQL=false

# ========================================
# MAINTENANCE MODE
# ========================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Server under maintenance. Please check back later.
