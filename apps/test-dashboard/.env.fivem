# FiveM to Dashboard API Bridge Configuration
# This file configures how the FiveM server communicates with the Next.js dashboard

# Dashboard API Settings
# Set to your dashboard URL - by default localhost:3000 for development
DASHBOARD_API_URL=http://localhost:3000/api

# Express server for two-way communication
# This will run on a separate port to receive updates from dashboard
FIVEM_API_PORT=3001
FIVEM_API_HOST=127.0.0.1

# Authentication token (set this for secure communication)
# Optional: Leave empty if running locally for development
API_AUTH_TOKEN=

# Polling interval for dashboard updates (milliseconds)
UPDATE_INTERVAL=5000

# Enable/disable features
ENABLE_PLAYER_TRACKING=true
ENABLE_ACTIVITY_LOGGING=true
ENABLE_SERVER_EVENTS=true
